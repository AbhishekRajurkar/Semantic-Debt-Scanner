import os
import glob
from dotenv import load_dotenv
from src.graph import build_graph

load_dotenv()

def main():
    # 1. Grab all python files from your synthetic folder
    target_dir = "messy_codebase"
    files = glob.glob(os.path.join(target_dir, "*.py"))
    
    if not files:
        print(f"No files found in {target_dir}. Please create some messy code!")
        return

    print(f"Initializing Semantic Router for {len(files)} files...")
    
    # 2. Compile Graph
    graph = build_graph()
    
    # 3. Define Initial State
    initial_state = {
        "file_queue": files,
        "current_file": None,
        "findings": [],
        "migration_strategy": ""
    }
    
    # 4. Execute the Graph Loop
    # We use stream() so you can see the nodes fire in real-time in your terminal
    final_state = None
    for output in graph.stream(initial_state, config={"recursion_limit": 100}):
        for node_name, state_update in output.items():
            print(f"--- Node Executed: {node_name} ---")
            final_state = state_update # Keep track of the final output

    # 5. Output the result
    print("\n\n" + "="*50)
    print("FINAL GEMINI REDUCE STRATEGY:")
    print("="*50)
    # The final state from the last node will contain the strategy
    print(final_state.get("migration_strategy", "Strategy generation failed."))

if __name__ == "__main__":
    main()
